rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /invite_codes/{code} {
      // Joinen leest een code via een directe get(); lijsten (enumeratie van
      // alle huishoudens) is bewust geblokkeerd.
      allow get: if request.auth != null;
      allow list: if false;
      allow create, delete: if request.auth != null;
    }
    match /households/{householdId}/members/{memberId} {
      // Iedereen mag zichzelf toevoegen als lid (voor aanmaken + joinen)
      allow create: if request.auth != null && request.auth.uid == memberId;
      // Lezen/schrijven mag als je al lid bent
      allow read, update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }
    match /households/{householdId}/meta/{docId} {
      // Lid mag meta lezen en schrijven
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
      // Bij aanmaken mag de creator meta/info schrijven (member-doc bestaat net)
      allow create: if request.auth != null;
    }
    match /households/{householdId}/{document=**} {
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }
  }
}
